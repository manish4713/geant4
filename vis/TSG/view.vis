/run/initialize
/vis/open TSG_OFFSCREEN
/vis/drawVolume
/vis/scene/add/axes 0 0 0 50 cm
/vis/viewer/set/viewpointThetaPhi 70 30
/vis/viewer/zoom 1.3

/vis/viewer/set/style wireframe
/vis/viewer/refresh

/tracking/storeTrajectory 1
/vis/modeling/trajectories/create/drawByParticleID
/vis/modeling/trajectories/drawByParticleID-0/set alpha 1 0 0
/vis/modeling/trajectories/drawByParticleID-0/set e- 1 1 0
/vis/modeling/trajectories/drawByParticleID-0/set gamma 0 1 1
/vis/modeling/trajectories/drawByParticleID-0/set neutron 1 0 1
/vis/scene/add/trajectories
/vis/scene/endOfEventAction accumulate 10
/vis/viewer/refresh